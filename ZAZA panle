<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>ZAZA PANLE X RED DARK HUB</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:linear-gradient(135deg,#050505,#1a0000,#000);
height:100vh;
display:flex;
justify-content:center;
align-items:center;
color:white;
}

.box{

width:400px;
background:rgba(20,0,0,.95);

border:2px solid #ff0000;

border-radius:25px;

padding:25px;

box-shadow:
0 0 20px red,
0 0 40px darkred;

animation: glow 2s infinite alternate;

}

@keyframes glow{

from{
box-shadow:0 0 20px red;
}

to{
box-shadow:0 0 45px crimson;
}

}

h1{

text-align:center;
color:#ff2d2d;

margin-bottom:20px;

text-shadow:0 0 12px red;

}

.menu{

background:#250000;

padding:12px;

border-radius:12px;

margin-bottom:18px;

text-align:center;

font-size:20px;

border:1px solid red;

}

.option{

display:flex;

justify-content:space-between;

align-items:center;

padding:15px;

margin:12px 0;

background:#130000;

border-radius:15px;

transition:.3s;

}

.option:hover{

transform:scale(1.04);

box-shadow:0 0 15px red;

}

input[type="checkbox"]{

width:24px;

height:24px;

accent-color:red;

}

button{

width:100%;

padding:14px;

border:none;

border-radius:14px;

background:red;

color:white;

font-size:18px;

cursor:pointer;

margin-top:15px;

transition:.3s;

}

button:hover{

background:#ff4040;

box-shadow:0 0 20px red;

}

.footer{

margin-top:18px;

text-align:center;

opacity:.7;

}

</style>

</head>
<body>

<div class="box">

<h1>ZAZA PANLE X RED DARK HUB</h1>

<div class="menu">
🔥 MENU PANEL 🔥
</div>

<div class="option">
<span>ล็อกหัว 79%</span>
<input type="checkbox">
</div>

<div class="option">
<span>DPI 200</span>
<input type="checkbox">
</div>

<button>START PANEL</button>

<div class="footer">
RED DARK VERSION
</div>

</div>

</body>
</html>
